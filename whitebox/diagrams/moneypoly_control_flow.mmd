flowchart TD
    A([Start]) --> B[Read player names]
    B --> C{At least two valid names?}
    C -- No --> D[Raise setup error and stop]
    C -- Yes --> E[Create Game, Board, Bank, Dice, Players, Decks]
    E --> F[Print welcome and starting balances]
    F --> G{Turns left and more than one player?}
    G -- No --> H[Find highest net-worth player]
    H --> I{Winner exists?}
    I -- Yes --> J[Print GAME OVER and winner]
    I -- No --> K[Print no players remaining]
    J --> L([End])
    K --> L
    G -- Yes --> M[Select current player and print turn banner]
    M --> N[Show pre-roll menu]
    N --> O{Player in jail?}
    O -- Yes --> P{Use jail-free card?}
    P -- Yes --> Q[Release player, roll, move, resolve tile]
    P -- No --> R{Pay jail fine?}
    R -- Yes --> S{Can afford fine?}
    S -- No --> T[Stay in jail and increment jail turns]
    S -- Yes --> U[Deduct fine, collect for bank, roll, move, resolve tile]
    R -- No --> T
    T --> V{Three jail turns served?}
    V -- Yes --> W[Force fine payment, roll, move, resolve tile]
    V -- No --> X[Advance turn]
    Q --> Y{Player eliminated?}
    U --> Y
    W --> Y
    Y -- Yes --> G
    Y -- No --> X
    O -- No --> Z[Roll dice]
    Z --> AA{Three doubles in a row?}
    AA -- Yes --> AB[Send player to jail]
    AB --> X
    AA -- No --> AC[Move player]
    AC --> AD[Inspect landed tile]
    AD --> AE{Tile type?}
    AE -- go_to_jail --> AF[Send player to jail]
    AE -- income_tax --> AG[Deduct tax and collect for bank]
    AE -- luxury_tax --> AH[Deduct tax and collect for bank]
    AE -- free_parking --> AI[Do nothing]
    AE -- chance/community --> AJ[Draw card and apply effect]
    AE -- railroad/property --> AK[Offer buy, auction, skip, or rent]
    AE -- go/jail/blank --> AL[No extra action]
    AF --> AM[Check bankruptcy]
    AG --> AM
    AH --> AM
    AI --> AM
    AJ --> AM
    AK --> AM
    AL --> AM
    AM --> AN{Player eliminated?}
    AN -- Yes --> G
    AN -- No --> AO{Rolled doubles?}
    AO -- Yes --> G
    AO -- No --> X
    X --> AP[Advance current player and turn counter]
    AP --> G
